# Supabase cloud sync (optional — the app runs local-only without these).
# Copy to .env.local for development; set the same two vars in Vercel for production.
# Values: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
